      "position": [
        1120,
        0
      ]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "warehouse-inventory",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "07942b63-d11a-4b8f-92a5-ecaba07775b0",
      "name": "Inventory Operations Webhook2",
